<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>
	<connectionStrings>
		<add name="DefaultConnection"
             connectionString="Data Source=localhost;Initial Catalog=PropertyInventory;Integrated Security=True;"
             providerName="System.Data.SqlClient" />
	</connectionStrings>
	<appSettings>
		<add key="CompanyName" value="Property Inventory System" />
		<add key="Version" value="1.0" />
	</appSettings>
</configuration>